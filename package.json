{
  "name": "pulse-uptime",
  "version": "0.3.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "postcss@<8.5.10": "^8.5.10",
      "@esbuild-kit/core-utils>esbuild": "^0.25.9"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node scripts/migrate-deploy.mjs && next build",
    "start": "next start",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "knip": "DATABASE_URL_UNPOOLED=postgres://knip@localhost/knip knip",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "query-perf:validate": "node --import ./scripts/query-performance/register.mjs scripts/query-performance/src/validate.ts",
    "query-perf:migrate": "node --import ./scripts/query-performance/register.mjs scripts/query-performance/src/migrate.ts",
    "query-perf:seed": "node --import ./scripts/query-performance/register.mjs scripts/query-performance/src/seed-fixture.ts",
    "query-perf:reset-fixture": "node --import ./scripts/query-performance/register.mjs scripts/query-performance/src/reset-fixture.ts",
    "query-perf:verify-state": "node --import ./scripts/query-performance/register.mjs scripts/query-performance/src/verify-state.ts",
    "query-perf:run": "node --import ./scripts/query-performance/register.mjs scripts/query-performance/src/run-benchmark.ts",
    "query-perf:compare": "node --import ./scripts/query-performance/register.mjs scripts/query-performance/src/compare-artifacts.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@radix-ui/react-select": "^2.3.3",
    "@react-email/components": "^1.0.4",
    "@vercel/edge-config": "^1.4.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "ipaddr.js": "^2.2.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "parse5": "^8.0.1",
    "postgres": "^3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "server-only": "^0.0.1",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "undici": "^7.18.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^27.4.0",
    "knip": "^6.27.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "ultracite": "7.9.4",
    "vitest": "^4.1.10"
  }
}
