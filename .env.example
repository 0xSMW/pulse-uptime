NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@host/pulse?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/pulse?sslmode=require
# Empty disposable database for the *.postgres.test.ts suites. See
# Docs/DEPLOYMENT.md section 2 for the local Docker and Neon options.
TEST_DATABASE_URL=
EDGE_CONFIG=https://edge-config.vercel.com/ecfg_example?token=example
EDGE_CONFIG_ID=ecfg_example
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
RESEND_API_KEY=re_example
RESEND_FROM_EMAIL=pulse@superposition.app
CRON_SECRET=replace-with-at-least-32-random-characters
API_TOKEN_HASH_KEY=replace-with-at-least-32-random-characters
DEVICE_AUTH_SECRET=replace-with-at-least-32-random-characters
# Immutable deployment identity recorded on every cron_runs row and used by
# release-bound deploy proof. On Vercel this is baked from VERCEL_DEPLOYMENT_ID
# at build time. Set an explicit stable value for local and tests.
PULSE_RELEASE_ID=local-dev
# Deprecated: used as the status page name only until the configuration is
# saved for the first time. Manage the page name in Settings → Status page.
NEXT_PUBLIC_STATUS_PAGE_NAME=Pulse Status
